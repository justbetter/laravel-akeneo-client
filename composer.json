{
    "name": "justbetter/laravel-akeneo-client",
    "description": "A Laravel package for the Akeneo API",
    "type": "package",
    "license": "MIT",
    "homepage": "https://github.com/justbetter/laravel-akeneo-client",
    "authors": [
        {
            "name": "Ramon Rietdijk",
            "email": "ramon@justbetter.nl",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "akeneo/api-php-client": "^11.4",
        "guzzlehttp/guzzle": "^7.5",
        "laravel/framework": "^12.0|^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^10.0|^11.0",
        "phpstan/phpstan-mockery": "^2.0",
        "phpunit/phpunit": "^13.0",
        "rector/rector": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "JustBetter\\AkeneoClient\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JustBetter\\AkeneoClient\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan --memory-limit=256M",
        "style": "pint --test",
        "quality": [
            "@style",
            "@analyse",
            "@test",
            "@coverage",
            "@rector"
        ],
        "fix-style": "pint",
        "coverage": "XDEBUG_MODE=coverage php -d memory_limit=2G vendor/bin/phpunit --coverage-text --only-summary-for-coverage-text | grep -c \"100.00%\" | grep -q \"^3$\" && exit 0 || exit 1",
        "rector": "rector process --dry-run"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true,
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "JustBetter\\AkeneoClient\\ServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
